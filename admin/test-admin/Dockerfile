# Використовуємо легкий образ Node.js
FROM node:20-alpine

# Встановлюємо робочу директорію
WORKDIR /app

# Копіюємо тільки файли залежностей (це прискорює збірку завдяки кешу)
COPY package.json yarn.lock ./

# Встановлюємо пакети
RUN yarn install --frozen-lockfile

# Копіюємо весь інший код проекту
COPY . .

# Відкриваємо порт, на якому працює Vite
EXPOSE 5173

# ЗАПУСК: додаємо --host, щоб застосунок був доступний ззовні контейнера
CMD ["yarn", "dev", "--host", "0.0.0.0"]